---
const year = new Date().getFullYear();
---
<style>
  .footer-bar {
    padding: 28px 0; border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
    max-width: 90%; margin: 8px auto 0;
  }
  .footer-left { font-size: 13px; color: var(--text-faint); letter-spacing: 0.08em; display: flex; flex-direction: column; gap: 4px; }
  .footer-left a { color: var(--text-faint); text-decoration: none; transition: color 0.2s; }
  .footer-left a:hover { color: var(--accent); }
  .footer-right { display: flex; gap: 28px; }
  .footer-link { font-size: 13px; color: var(--text-faint); letter-spacing: 0.08em; transition: color 0.2s; text-decoration: none; }
  .footer-link:hover { color: var(--accent); }
</style>

<div class="footer-bar">
  <div class="footer-left">
    <span>shannanji.com · {year}</span>
    <a href="https://beian.miit.gov.cn" target="_blank" rel="noopener">陕ICP备2026005269号</a>
    <a href="https://beian.gov.cn" target="_blank" rel="noopener">陕公网安备61070202000622号</a>
  </div>
  <div class="footer-right">
    <a class="footer-link" href="https://github.com/DuLiCS">github</a>
    <a class="footer-link" href="/rss.xml">rss</a>
    <a class="footer-link" href="/about">about</a>
  </div>
</div>
