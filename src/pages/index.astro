---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const recent = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const tagCount: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 7).replace('-', '.');
}
---
<BaseLayout>
<style>
  .container { max-width: 1000px; margin: 0 auto; width: 100%; padding: 0 48px; }

  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0; border-bottom: 1px solid #e8e6e0;
    max-width: 860px; margin: 0 auto;
  }
  .logo { font-size: 14px; color: #999; letter-spacing: 0.12em; text-decoration: none; }
  .logo span { color: #3d7a56; }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { font-size: 13px; color: #aaa; letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: #2a2a28; }
  .lang-toggle {
    font-size: 12px; color: #bbb; letter-spacing: 0.1em; cursor: pointer;
    border: 1px solid #e0ddd8; padding: 5px 12px; border-radius: 2px; transition: all 0.2s;
  }
  .lang-toggle:hover { border-color: #3d7a56; color: #3d7a56; }

  .hero { padding: 52px 0 32px; max-width: 860px; margin: 0 auto; }
  .hero-eyebrow { font-size: 11px; color: #3d7a56; letter-spacing: 0.28em; margin-bottom: 28px; text-transform: uppercase; }
  .hero-title-line1 {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 14px; font-weight: 300; color: #b0ada8;
    letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 12px;
  }
  .hero-title-line2 {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 36px; font-weight: 300; color: #1a1a18;
    line-height: 1.45; letter-spacing: 0.02em;
    border-left: 2px solid #3d7a56; padding-left: 24px; margin-bottom: 36px;
  }
  .cursor {
    display: inline-block; width: 2px; height: 32px;
    background: #3d7a56; margin-left: 4px; vertical-align: middle;
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .section { max-width: 860px; margin: 0 auto 52px; }
  .section-label {
    font-size: 11px; color: #c0bdb8; letter-spacing: 0.3em;
    margin-bottom: 20px; padding-top: 24px; border-top: 1px solid #eeece8;
  }
  .posts-list { display: flex; flex-direction: column; }
  .post-row {
    display: grid; grid-template-columns: 88px 1fr 20px;
    align-items: baseline; gap: 28px; padding: 20px 0;
    border-bottom: 1px solid #f0ede8; cursor: pointer; text-decoration: none;
  }
  .post-row:hover .post-title { color: #1a1a18; }
  .post-row:hover .post-arrow { opacity: 1; }
  .post-date { font-size: 12px; color: #c0bdb8; letter-spacing: 0.06em; }
  .post-center { display: flex; flex-direction: column; gap: 5px; }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; font-weight: 400; color: #3a3a36;
    line-height: 1.5; transition: color 0.15s;
  }
  .post-tag { font-size: 11px; color: #3d7a56; letter-spacing: 0.1em; }
  .post-arrow { font-size: 13px; color: #c0bdb8; opacity: 0; transition: opacity 0.15s; }

  .section-footer { padding-top: 20px; }
  .all-link { font-size: 12px; color: #aaa; letter-spacing: 0.1em; text-decoration: none; transition: color 0.2s; }
  .all-link:hover { color: #3d7a56; }

  .category-row { display: flex; flex-wrap: wrap; }
  .cat-chip {
    font-size: 12px; color: #888; letter-spacing: 0.08em;
    border: 1px solid #e8e6e0; padding: 7px 16px;
    margin: 0 8px 8px 0; border-radius: 2px; cursor: pointer;
    transition: all 0.15s; display: flex; align-items: center; gap: 6px; text-decoration: none;
  }
  .cat-chip:hover { border-color: #3d7a56; color: #3d7a56; }
  .cat-chip .count { font-size: 11px; color: #c8c5c0; }

  .footer-bar {
    padding: 28px 0; border-top: 1px solid #eeece8;
    display: flex; justify-content: space-between; align-items: center;
    max-width: 860px; margin: 8px auto 0;
  }
  .footer-left { font-size: 12px; color: #c8c5c0; letter-spacing: 0.08em; }
  .footer-right { display: flex; gap: 28px; }
  .footer-link { font-size: 12px; color: #c0bdb8; letter-spacing: 0.08em; transition: color 0.2s; text-decoration: none; }
  .footer-link:hover { color: #3d7a56; }
</style>

<div class="container">
  <nav>
    <a href="/" class="logo"><span>/</span> shannanji</a>
    <ul class="nav-links">
      <li><a href="/writing">writing</a></li>
      <li><a href="/notes">notes</a></li>
      <li><a href="/about">about</a></li>
      <li><a href="/rss.xml">rss</a></li>
    </ul>
    <div class="lang-toggle">EN / 中</div>
  </nav>

  <div class="hero">
    <div class="hero-eyebrow">blood, sweat &amp; tears</div>
    <div class="hero-title-line1">whatever people say i am,</div>
    <div class="hero-title-line2">
      that's what i'm not.<span class="cursor"></span>
    </div>
  </div>

  <div class="section">
    <div class="section-label">RECENT WRITING</div>
    <div class="posts-list">
      {recent.map(post => (
        <a class="post-row" href={`/posts/${post.id}`}>
          <span class="post-date">{formatDate(post.data.date)}</span>
          <div class="post-center">
            <div class="post-title">{post.data.title}</div>
            <div class="post-tag">{post.data.tags?.[0]}</div>
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>
    <div class="section-footer">
      <a class="all-link" href="/writing">all writing →</a>
    </div>
  </div>

<div class="section">
  <div class="section-label">TOPICS</div>
  <div class="category-row">
{tags.map(([tag, count]) => (
  <a class="cat-chip" href={`/topics/${tag}`}>{tag} <span class="count">{count}</span></a>
))}
  </div>
</div>

  <Footer />
</div>
</BaseLayout>