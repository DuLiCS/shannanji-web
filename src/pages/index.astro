---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { formatYearMonth } from '../utils/date';

const allPosts = await getCollection('posts');
const recent = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const tagCount: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);
---
<BaseLayout>
<style>
  .hero { padding: 64px 0 48px; border-bottom: 1px solid var(--border); }
  .hero-eyebrow { font-size: 12px; color: var(--accent); letter-spacing: 0.28em; margin-bottom: 28px; text-transform: uppercase; }
  .hero-title-line1 {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 15px; font-weight: 400; color: var(--text-muted);
    letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 12px;
  }
  .hero-title-line2 {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 48px; font-weight: 400; color: var(--text);
    line-height: 1.3; letter-spacing: 0.02em;
    border-left: 3px solid var(--accent); padding-left: 28px; margin-bottom: 0;
  }
  .hero-attribution {
    font-size: 11px; color: var(--text-faint); letter-spacing: 0.2em;
    padding-left: 31px; margin-top: 20px;
  }
  .cursor {
    display: inline-block; width: 3px; height: 44px;
    background: var(--accent); margin-left: 4px; vertical-align: middle;
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 80px;
    padding: 48px 0;
    align-items: start;
  }

  .section-label {
    font-size: 11px; color: var(--text-faint); letter-spacing: 0.3em;
    margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--border);
  }

  .posts-list { display: flex; flex-direction: column; }
  .post-row {
    display: grid; grid-template-columns: 100px 1fr 20px;
    align-items: baseline; gap: 28px; padding: 20px 0;
    border-bottom: 1px solid var(--border-light); cursor: pointer; text-decoration: none;
    transition: opacity 0.15s;
  }
  .post-row:hover { opacity: 0.7; }
  .post-row:hover .post-arrow { opacity: 1; }
  .post-date { font-size: 15px; color: var(--text-faint); letter-spacing: 0.06em; }
  .post-center { display: flex; flex-direction: column; gap: 5px; }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 22px; font-weight: 400; color: var(--text); line-height: 1.5;
  }
  .post-tag { font-size: 12px; color: var(--accent); letter-spacing: 0.1em; }
  .post-arrow { font-size: 14px; color: var(--text-faint); opacity: 0; transition: opacity 0.15s; }

  .section-footer { padding-top: 20px; }
  .all-link { font-size: 13px; color: var(--text-muted); letter-spacing: 0.1em; text-decoration: none; transition: color 0.2s; }
  .all-link:hover { color: var(--accent); }

  .side-col { display: flex; flex-direction: column; gap: 40px; }

  .category-row { display: flex; flex-wrap: wrap; gap: 0; }
  .cat-chip {
    font-size: 14px; color: var(--text-muted); letter-spacing: 0.08em;
    border: 1px solid var(--border); padding: 7px 14px;
    margin: 0 6px 6px 0; border-radius: 2px; cursor: pointer;
    transition: all 0.15s; display: flex; align-items: center; gap: 5px;
  }
  .cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .cat-chip .count { font-size: 11px; color: var(--text-faint); }

  .about-block { }
  .about-text {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 15px; color: var(--text-muted); line-height: 2;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 28px 0;
    }
    .side-col {
      border-left: none;
      border-top: 1px solid var(--border);
      padding-top: 28px;
      gap: 24px;
    }
    .post-row {
      grid-template-columns: 64px 1fr;
      gap: 10px;
      padding: 14px 0;
    }
    .post-arrow { display: none; }
    .post-title { font-size: 16px; line-height: 1.6; }
    .post-date { font-size: 12px; }
    .hero-title-line2 { font-size: 28px; padding-left: 14px; }
  }
</style>

<div class="container">
  <SiteNav />

  <div class="hero">
    <div class="hero-eyebrow">blood, sweat &amp; tears</div>
    <div class="hero-title-line1">whatever people say i am,</div>
    <div class="hero-title-line2">
      that's what i'm not.<span class="cursor"></span>
    </div>
    <div class="hero-attribution">— Alan Sillitoe, Saturday Night and Sunday Morning, 1958</div>
  </div>

  <div class="content-grid">
    <div class="main-col">
      <div class="section-label">RECENT WRITING</div>
      <div class="posts-list">
        {recent.map(post => (
          <a class="post-row" href={`/posts/${post.id}`}>
            <span class="post-date">{formatYearMonth(post.data.date)}</span>
            <div class="post-center">
              <div class="post-title">{post.data.title}</div>
              <div class="post-tag">{post.data.tags?.[0]}</div>
            </div>
            <span class="post-arrow">→</span>
          </a>
        ))}
      </div>
      <div class="section-footer">
        <a class="all-link" href="/writing">all writing →</a>
      </div>
    </div>

    <div class="side-col">
      <div class="about-block">
        <div class="section-label">ABOUT</div>
        <div class="about-text">
          dulics@gmail.com<br/>
          WeChat:IEEE811
        </div>
      </div>

      <div>
        <div class="section-label">TOPICS</div>
        <div class="category-row">
          {tags.map(([tag, count]) => (
            <a class="cat-chip" href={`/writing?tag=${tag}`}>{tag} <span class="count">{count}</span></a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <Footer />
</div>
</BaseLayout>