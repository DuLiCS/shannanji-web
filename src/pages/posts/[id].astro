---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10);
}
---
<BaseLayout title={`${post.data.title} — shannanji`}>
<style>
  .container { max-width: 1000px; margin: 0 auto; width: 100%; padding: 0 48px; }

  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0; border-bottom: 1px solid #e8e6e0;
    max-width: 860px; margin: 0 auto;
  }
  .logo { font-size: 14px; color: #999; letter-spacing: 0.12em; text-decoration: none; }
  .logo span { color: #3d7a56; }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { font-size: 13px; color: #aaa; letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: #2a2a28; }

  .post-header { padding: 52px 0 36px; max-width: 860px; margin: 0 auto; }
  .post-meta-top { display: flex; gap: 16px; align-items: center; margin-bottom: 24px; }
  .post-date { font-size: 12px; color: #c0bdb8; letter-spacing: 0.08em; }
  .post-tag {
    font-size: 11px; color: #3d7a56; letter-spacing: 0.1em;
    border: 1px solid #d0e8da; padding: 3px 10px; border-radius: 2px;
  }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 36px; font-weight: 400; color: #1a1a18;
    line-height: 1.4; margin-bottom: 12px;
  }
  .post-subtitle {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 18px; font-weight: 300; color: #999; line-height: 1.6;
  }

  .post-body { padding: 0 0 80px; max-width: 720px; margin: 0 auto; }

  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-weight: 400; color: #1a1a18; margin: 2em 0 0.8em;
  }
  .post-body :global(h1) { font-size: 26px; }
  .post-body :global(h2) { font-size: 22px; }
  .post-body :global(h3) { font-size: 19px; }

  .post-body :global(p) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; color: #3a3a36; line-height: 2.1;
    margin-bottom: 1.4em; font-weight: 300;
  }

  .post-body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px; background: #f6f4f0;
    padding: 2px 6px; border-radius: 3px; color: #3d7a56;
  }

  .post-body :global(pre) {
    background: #f6f4f0; padding: 20px 24px;
    border-radius: 4px; overflow-x: auto; margin: 1.6em 0;
    border-left: 2px solid #3d7a56;
  }

  .post-body :global(pre code) {
    background: none; padding: 0; color: #3a3a36;
    font-size: 14px; line-height: 1.8;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid #e0ddd8; padding-left: 24px;
    margin: 1.6em 0; color: #888; font-style: italic;
  }

  .post-body :global(img) { max-width: 100%; border-radius: 4px; margin: 1.6em 0; }

  .post-body :global(a) {
    color: #3d7a56; text-decoration: underline;
    text-decoration-color: #c0ddd0;
  }

  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }

  .post-body :global(li) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; color: #3a3a36; line-height: 2.1; font-weight: 300;
  }

  .post-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.6em 0; font-size: 15px; }
  .post-body :global(th) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: #888; letter-spacing: 0.08em;
    border-bottom: 1px solid #e8e6e0; padding: 10px 14px; text-align: left; font-weight: 400;
  }
  .post-body :global(td) { padding: 12px 14px; border-bottom: 1px solid #f0ede8; color: #3a3a36; vertical-align: top; }

  .post-nav { padding: 32px 0; border-top: 1px solid #eeece8; max-width: 860px; margin: 0 auto; }
  .back-link { font-size: 13px; color: #aaa; letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: #3d7a56; }
</style>

<div class="container">
  <nav>
    <a href="/" class="logo"><span>/</span> shannanji</a>
    <ul class="nav-links">
      <li><a href="/writing">writing</a></li>
      <li><a href="/notes">notes</a></li>
      <li><a href="/about">about</a></li>
      <li><a href="/rss.xml">rss</a></li>
    </ul>
  </nav>

  <div class="post-header">
    <div class="post-meta-top">
      <span class="post-date">{formatDate(post.data.date)}</span>
      {post.data.tags && post.data.tags.map((tag: string) => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
    <div class="post-title">{post.data.title}</div>
    {post.data.subtitle && (
      <div class="post-subtitle">{post.data.subtitle}</div>
    )}
  </div>

  <div class="post-body">
    <Content />
  </div>

  <div class="post-nav">
    <a class="back-link" href="/writing">← back to writing</a>
  </div>
</div>
</BaseLayout>