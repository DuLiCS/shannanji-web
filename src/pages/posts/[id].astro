---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import SiteNav from '../../components/SiteNav.astro';
import { getCollection, render } from 'astro:content';
import { formatFullDate } from '../../utils/date';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: { post, prev: posts[i + 1] ?? null, next: posts[i - 1] ?? null },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const description = post.data.subtitle ?? post.data.tags?.join(' · ') ?? post.data.title;
---
<BaseLayout title={`${post.data.title} — 山南记`} description={description}>
<style>
  #reading-progress {
    position: fixed; top: 0; left: 0; height: 2px; width: 0%;
    background: var(--accent); z-index: 100; transition: width 0.1s linear;
  }

  .post-header { padding: 52px 0 36px; max-width: 740px; margin: 0 auto; }
  .post-meta-top { display: flex; gap: 16px; align-items: center; margin-bottom: 24px; }
  .post-date { font-size: 13px; color: var(--text-faint); letter-spacing: 0.08em; }
  .post-tag {
    font-size: 12px; color: var(--accent); letter-spacing: 0.1em;
    border: 1px solid var(--accent-light); padding: 3px 10px; border-radius: 2px;
  }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 44px; font-weight: 400; color: var(--text);
    line-height: 1.4; margin-bottom: 12px;
  }
  .post-subtitle {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 19px; font-weight: 300; color: var(--text-muted); line-height: 1.6;
  }

  .post-body { padding: 0 0 80px; max-width: 740px; margin: 0 auto; }

  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-weight: 400; color: var(--text); margin: 2em 0 0.8em;
  }
  .post-body :global(h1) { font-size: 28px; }
  .post-body :global(h2) { font-size: 23px; }
  .post-body :global(h3) { font-size: 20px; }

  .post-body :global(p) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 20px; color: var(--text); line-height: 2.1;
    margin-bottom: 1.4em; font-weight: 400;
    text-indent: 2em;
  }
  .post-body :global(blockquote p),
  .post-body :global(li p),
  .post-body :global(h1 + p),
  .post-body :global(h2 + p),
  .post-body :global(h3 + p) {
    text-indent: 0;
  }

  .post-body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px; background: var(--bg-secondary);
    padding: 2px 6px; border-radius: 3px; color: var(--accent);
  }

  .post-body :global(pre) {
    background: var(--bg-secondary); padding: 20px 24px;
    border-radius: 4px; overflow-x: auto; margin: 1.6em 0;
    border-left: 2px solid var(--accent);
  }

  .post-body :global(pre code) {
    background: none; padding: 0; color: var(--text);
    font-size: 14px; line-height: 1.8;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--border); padding-left: 24px;
    margin: 1.6em 0; color: var(--text-muted); font-style: italic;
  }

  .post-body :global(img) { max-width: 100%; border-radius: 4px; margin: 1.6em 0; }

  .post-body :global(a) {
    color: var(--accent); text-decoration: underline;
    text-decoration-color: var(--accent-light);
  }

  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }

  .post-body :global(li) {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 20px; color: var(--text); line-height: 2.1; font-weight: 400;
  }

  .post-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.6em 0; font-size: 15px; }
  .post-body :global(th) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--text-muted); letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border); padding: 10px 14px; text-align: left; font-weight: 400;
  }
  .post-body :global(td) {
    padding: 12px 14px; border-bottom: 1px solid var(--border-light);
    color: var(--text); vertical-align: top;
  }

  .post-nav {
    padding: 32px 0; border-top: 1px solid var(--border);
    max-width: 740px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px;
  }
  .nav-prev, .nav-next {
    display: flex; flex-direction: column; gap: 4px; text-decoration: none;
    transition: opacity 0.2s;
  }
  .nav-prev:hover, .nav-next:hover { opacity: 0.7; }
  .nav-next { text-align: right; margin-left: auto; }
  .nav-dir { font-size: 11px; color: var(--text-faint); letter-spacing: 0.2em; }
  .nav-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 15px; color: var(--text-muted); line-height: 1.4;
  }
  .nav-back { font-size: 13px; color: var(--text-faint); letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; text-align: center; }
  .nav-back:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .post-nav { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; }
    .nav-back { grid-column: 1 / -1; order: -1; }
    .post-title { font-size: 28px; }
  }
</style>

<div id="reading-progress"></div>
<div class="container">
  <SiteNav />

  <div class="post-header">
    <div class="post-meta-top">
      <span class="post-date">{formatFullDate(post.data.date)}</span>
      {post.data.tags && post.data.tags.map((tag: string) => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
    <div class="post-title">{post.data.title}</div>
    {post.data.subtitle && (
      <div class="post-subtitle">{post.data.subtitle}</div>
    )}
  </div>

  <div class="post-body">
    <Content />
  </div>

  <div class="post-nav">
    {prev ? (
      <a class="nav-prev" href={`/posts/${prev.id}`}>
        <span class="nav-dir">← older</span>
        <span class="nav-title">{prev.data.title}</span>
      </a>
    ) : <span />}
    <a class="nav-back" href="/writing">all writing</a>
    {next ? (
      <a class="nav-next" href={`/posts/${next.id}`}>
        <span class="nav-dir">newer →</span>
        <span class="nav-title">{next.data.title}</span>
      </a>
    ) : <span />}
  </div>

  <Footer />
</div>

<script>
  const bar = document.getElementById('reading-progress') as HTMLElement;
  document.addEventListener('scroll', () => {
    const scrolled = window.scrollY;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
  }, { passive: true });
</script>
</BaseLayout>