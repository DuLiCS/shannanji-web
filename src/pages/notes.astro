---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';
---
<BaseLayout title="notes — 山南记">
<style>
  .body { max-width: 860px; margin: 0 auto; padding: 64px 0; }
  .label { font-size: 11px; color: var(--text-faint); letter-spacing: 0.3em; margin-bottom: 24px; }
  .placeholder {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; color: var(--text-faint); font-weight: 300; line-height: 2;
  }
</style>
<div class="container">
  <SiteNav active="notes" />
  <div class="body">
    <div class="label">NOTES</div>
    <div class="placeholder">碎片、摘录、随想。暂未开放，敬请期待。</div>
  </div>
  <Footer />
</div>
</BaseLayout>