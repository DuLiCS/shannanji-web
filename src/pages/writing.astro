---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 7).replace('-', '.');
}
---
<BaseLayout title="writing — shannanji">
<style>
  .container { max-width: 1000px; margin: 0 auto; width: 100%; padding: 0 48px; }

  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0; border-bottom: 1px solid #e8e6e0;
    max-width: 860px; margin: 0 auto;
  }
  .logo { font-size: 14px; color: #999; letter-spacing: 0.12em; text-decoration: none; }
  .logo span { color: #3d7a56; }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { font-size: 13px; color: #aaa; letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: #2a2a28; }
  .nav-links a.active { color: #2a2a28; }

  .page-header { padding: 48px 0 28px; max-width: 860px; margin: 0 auto; }
  .page-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 14px; font-weight: 300; color: #b0ada8; letter-spacing: 0.18em; text-transform: uppercase;
  }

  .section { max-width: 860px; margin: 0 auto 52px; }
  .posts-list { display: flex; flex-direction: column; }
  .post-row {
    display: grid; grid-template-columns: 88px 1fr 20px;
    align-items: baseline; gap: 28px; padding: 20px 0;
    border-bottom: 1px solid #f0ede8; cursor: pointer; text-decoration: none;
  }
  .post-row:hover .post-title { color: #1a1a18; }
  .post-row:hover .post-arrow { opacity: 1; }
  .post-date { font-size: 12px; color: #c0bdb8; letter-spacing: 0.06em; }
  .post-center { display: flex; flex-direction: column; gap: 5px; }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; font-weight: 400; color: #3a3a36; line-height: 1.5; transition: color 0.15s;
  }
  .post-meta { display: flex; gap: 12px; align-items: center; }
  .post-tag { font-size: 11px; color: #3d7a56; letter-spacing: 0.1em; }
  .post-subtitle { font-size: 12px; color: #b0ada8; }
  .post-arrow { font-size: 13px; color: #c0bdb8; opacity: 0; transition: opacity 0.15s; }

  .footer-bar {
    padding: 28px 0; border-top: 1px solid #eeece8;
    display: flex; justify-content: space-between; align-items: center;
    max-width: 860px; margin: 8px auto 0;
  }
  .footer-left { font-size: 12px; color: #c8c5c0; letter-spacing: 0.08em; }
  .footer-right { display: flex; gap: 28px; }
  .footer-link { font-size: 12px; color: #c0bdb8; letter-spacing: 0.08em; transition: color 0.2s; text-decoration: none; }
  .footer-link:hover { color: #3d7a56; }
</style>

<div class="container">
  <nav>
    <a href="/" class="logo"><span>/</span> shannanji</a>
    <ul class="nav-links">
      <li><a href="/writing" class="active">writing</a></li>
      <li><a href="/notes">notes</a></li>
      <li><a href="/about">about</a></li>
      <li><a href="/rss.xml">rss</a></li>
    </ul>
  </nav>

  <div class="page-header">
    <div class="page-title">all writing — {sorted.length} posts</div>
  </div>

  <div class="section">
    <div class="posts-list">
      {sorted.map(post => (
        <a class="post-row" href={`/posts/${post.id}`}>
          <span class="post-date">{formatDate(post.data.date)}</span>
          <div class="post-center">
            <div class="post-title">{post.data.title}</div>
            <div class="post-meta">
              {post.data.subtitle && <span class="post-subtitle">{post.data.subtitle}</span>}
              {post.data.tags && post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>
  </div>

  <Footer />
</div>
</BaseLayout>