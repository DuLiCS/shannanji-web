---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 7).replace('-', '.');
}
---
<BaseLayout title="文章 — 山南记">
<style>
  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0; border-bottom: 1px solid var(--border);
    max-width: 90%; margin: 0 auto;
  }
  .logo { font-size: 15px; color: var(--text-muted); letter-spacing: 0.12em; text-decoration: none; }
  .logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { font-size: 14px; color: var(--text-faint); letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--text); }
  .nav-right { display: flex; align-items: center; gap: 20px; }

  .page-header { padding: 48px 0 28px; max-width: 90%; margin: 0 auto; }
  .page-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 15px; font-weight: 400; color: var(--text-muted); letter-spacing: 0.18em; text-transform: uppercase;
  }

  .section { max-width: 90%; margin: 0 auto 52px; }
  .posts-list { display: flex; flex-direction: column; }
  .post-row {
    display: grid; grid-template-columns: 96px 1fr 20px;
    align-items: baseline; gap: 28px; padding: 20px 0;
    border-bottom: 1px solid var(--border-light); cursor: pointer; text-decoration: none;
    transition: opacity 0.15s;
  }
  .post-row:hover { opacity: 0.75; }
  .post-row:hover .post-arrow { opacity: 1; }
  .post-date { font-size: 13px; color: var(--text-faint); letter-spacing: 0.06em; }
  .post-center { display: flex; flex-direction: column; gap: 5px; }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 18px; font-weight: 400; color: var(--text); line-height: 1.5;
  }
  .post-meta { display: flex; gap: 12px; align-items: center; }
  .post-tag { font-size: 12px; color: var(--accent); letter-spacing: 0.1em; }
  .post-subtitle { font-size: 13px; color: var(--text-muted); }
  .post-arrow { font-size: 14px; color: var(--text-faint); opacity: 0; transition: opacity 0.15s; }
</style>

<div class="container">
  <nav>
    <a href="/" class="logo"><span>/</span> shannanji</a>
    <ul class="nav-links">
      <li><a href="/writing" class="active">writing</a></li>
      <li><a href="/notes">notes</a></li>
      <li><a href="/about">about</a></li>
      <li><a href="/rss.xml">rss</a></li>
    </ul>
    <div class="nav-right">
      <ThemeToggle />
    </div>
  </nav>

  <div class="page-header">
    <div class="page-title">all writing — {sorted.length} posts</div>
  </div>

  <div class="section">
    <div class="posts-list">
      {sorted.map(post => (
        <a class="post-row" href={`/posts/${post.id}`}>
          <span class="post-date">{formatDate(post.data.date)}</span>
          <div class="post-center">
            <div class="post-title">{post.data.title}</div>
            <div class="post-meta">
              {post.data.subtitle && <span class="post-subtitle">{post.data.subtitle}</span>}
              {post.data.tags && post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>
  </div>

  <Footer />
</div>
</BaseLayout>