---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { formatYearMonth } from '../utils/date';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const tagCount: { [key: string]: number } = {};
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]).map(([t]) => t);

const grouped: Record<string, typeof sorted> = {};
for (const post of sorted) {
  const year = new Date(post.data.date).getFullYear().toString();
  if (!grouped[year]) grouped[year] = [];
  grouped[year].push(post);
}
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---
<BaseLayout title="文章 — 山南记">
<style>
  .year-group { position: relative; overflow: hidden; }
  .year-bg {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 400;
    color: var(--text);
    opacity: 0.045;
    line-height: 1;
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
    position: absolute;
    top: -8px;
    left: -4px;
    z-index: 0;
  }
  .year-posts { position: relative; z-index: 1; }
</style>
<div class="container">
  <SiteNav active="writing" />

  <div class="writing-header">
    <div class="writing-title">all writing — {sorted.length} posts</div>
    <div class="tag-filters">
      <button class="tag-f" data-active="true" data-tag="all">all</button>
      {topTags.map(tag => (
        <button class="tag-f" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </div>

  <div class="writing-list">
    {years.map(year => (
      <div class="year-group">
        <div class="year-bg" aria-hidden="true">{year}</div>
        <div class="year-posts">
          {grouped[year].map(post => (
            <a class="writing-row" href={"/posts/" + post.id} data-tags={post.data.tags?.join(",") ?? ""}>
              <span class="writing-date">{formatYearMonth(post.data.date)}</span>
              <div class="writing-center">
                <div class="writing-post-title">{post.data.title}</div>
                {post.data.subtitle && <div class="writing-subtitle">{post.data.subtitle}</div>}
              </div>
              <div class="writing-tag">{post.data.tags?.[0]}</div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <Footer />
</div>

<script>
  const filters = document.querySelectorAll(".tag-f");
  const rows = document.querySelectorAll(".writing-row");

  function applyFilter(tag: string) {
    filters.forEach(b => (b as HTMLElement).removeAttribute("data-active"));
    const activeBtn = document.querySelector(`.tag-f[data-tag="${tag}"]`) as HTMLElement;
    if (activeBtn) activeBtn.setAttribute("data-active", "true");
    rows.forEach(row => {
      const el = row as HTMLElement;
      if (tag === "all") {
        el.style.display = "";
      } else {
        const tags = el.dataset.tags || "";
        el.style.display = tags.split(",").includes(tag) ? "" : "none";
      }
    });
    // hide year groups where all posts are filtered out
    document.querySelectorAll<HTMLElement>(".year-group").forEach(group => {
      const visible = group.querySelectorAll<HTMLElement>('.writing-row:not([style*="none"])');
      group.style.display = visible.length === 0 ? "none" : "";
    });
  }

  const urlTag = new URLSearchParams(window.location.search).get("tag") || "all";
  applyFilter(urlTag);

  filters.forEach(btn => {
    btn.addEventListener("click", () => {
      const tag = (btn as HTMLElement).dataset.tag || "all";
      applyFilter(tag);
    });
  });
</script>
</BaseLayout>
