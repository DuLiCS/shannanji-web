---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="about — 山南记">
<style>
  .container { max-width: 1000px; margin: 0 auto; width: 100%; padding: 0 48px; }
  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0; border-bottom: 1px solid #e8e6e0;
    max-width: 860px; margin: 0 auto;
  }
  .logo { font-size: 14px; color: #999; letter-spacing: 0.12em; text-decoration: none; }
  .logo span { color: #3d7a56; }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { font-size: 13px; color: #aaa; letter-spacing: 0.08em; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: #2a2a28; }
  .nav-links a.active { color: #2a2a28; }

  .body { max-width: 860px; margin: 0 auto; padding: 64px 0; }
  .label { font-size: 11px; color: #c0bdb8; letter-spacing: 0.3em; margin-bottom: 32px; }

  .about-text {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; color: #3a3a36; font-weight: 300;
    line-height: 2.1; max-width: 620px;
  }
  .about-text p { margin-bottom: 1.6em; }

  .links { margin-top: 48px; display: flex; flex-direction: column; gap: 12px; }
  .link-row { display: flex; align-items: center; gap: 20px; }
  .link-label { font-size: 11px; color: #c0bdb8; letter-spacing: 0.2em; width: 80px; }
  .link-url {
    font-size: 13px; color: #3d7a56; text-decoration: none;
    letter-spacing: 0.04em; transition: opacity 0.2s;
  }
  .link-url:hover { opacity: 0.7; }

  .footer-bar {
    padding: 28px 0; border-top: 1px solid #eeece8;
    display: flex; justify-content: space-between; align-items: center;
    max-width: 860px; margin: 8px auto 0;
  }
  .footer-left { font-size: 12px; color: #c8c5c0; letter-spacing: 0.08em; }
  .footer-right { display: flex; gap: 28px; }
  .footer-link { font-size: 12px; color: #c0bdb8; letter-spacing: 0.08em; transition: color 0.2s; text-decoration: none; }
  .footer-link:hover { color: #3d7a56; }
</style>
<div class="container">
  <nav>
    <a href="/" class="logo"><span>/</span> shannanji</a>
    <ul class="nav-links">
      <li><a href="/writing">writing</a></li>
      <li><a href="/notes">notes</a></li>
      <li><a href="/about" class="active">about</a></li>
      <li><a href="/rss.xml">rss</a></li>
    </ul>
  </nav>

  <div class="body">
    <div class="label">ABOUT</div>
    <div class="about-text">
      <p>dulics@gmail.com</p>
      <p>WeChat:IEEE811</p>
      <p>这个站是思考的轨迹，不是简历。</p>
    </div>

    <div class="links">
      <div class="link-row">
        <span class="link-label">GITHUB</span>
        <a class="link-url" href="https://github.com/DuLiCS" target="_blank">github.com/DuLiCS</a>
      </div>
      <div class="link-row">
        <span class="link-label">RSS</span>
        <a class="link-url" href="/rss.xml">/rss.xml</a>
      </div>
    </div>
  </div>
  <Footer />  
</div>
</BaseLayout>