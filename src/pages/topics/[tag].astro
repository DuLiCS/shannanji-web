---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import SiteNav from '../../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { formatYearMonth } from '../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagSet.add(tag);
    }
  }
  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection('posts');
const filtered = allPosts
  .filter(post => post.data.tags?.includes(tag))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

---
<BaseLayout title={`${tag} — 山南记`}>
<style>
  .page-header { padding: 48px 0 28px; max-width: 860px; margin: 0 auto; }
  .page-label { font-size: 11px; color: var(--text-faint); letter-spacing: 0.3em; margin-bottom: 12px; }
  .page-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 28px; font-weight: 300; color: var(--text);
  }
  .page-count { font-size: 12px; color: var(--text-faint); margin-top: 6px; }

  .section { max-width: 860px; margin: 0 auto 52px; }
  .posts-list { display: flex; flex-direction: column; }
  .post-row {
    display: grid; grid-template-columns: 88px 1fr 20px;
    align-items: baseline; gap: 28px; padding: 20px 0;
    border-bottom: 1px solid var(--border-light); cursor: pointer; text-decoration: none;
  }
  .post-row:hover .post-title { color: var(--text); }
  .post-row:hover .post-arrow { opacity: 1; }
  .post-date { font-size: 12px; color: var(--text-faint); letter-spacing: 0.06em; }
  .post-center { display: flex; flex-direction: column; gap: 5px; }
  .post-title {
    font-family: 'LXGW WenKai', 'Noto Serif SC', serif;
    font-size: 17px; font-weight: 400; color: var(--text-muted); line-height: 1.5; transition: color 0.15s;
  }
  .post-tag { font-size: 11px; color: var(--accent); letter-spacing: 0.1em; }
  .post-arrow { font-size: 13px; color: var(--text-faint); opacity: 0; transition: opacity 0.15s; }

  .back-link-wrap { max-width: 860px; margin: 0 auto; padding: 24px 0; border-top: 1px solid var(--border-light); }
  .back-link { font-size: 13px; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: var(--accent); }
</style>

<div class="container">
  <SiteNav />

  <div class="page-header">
    <div class="page-label">TOPIC</div>
    <div class="page-title">{tag}</div>
    <div class="page-count">{filtered.length} 篇</div>
  </div>

  <div class="section">
    <div class="posts-list">
      {filtered.map(post => (
        <a class="post-row" href={`/posts/${post.id}`}>
          <span class="post-date">{formatYearMonth(post.data.date)}</span>
          <div class="post-center">
            <div class="post-title">{post.data.title}</div>
            <div class="post-tag">{post.data.tags?.[0]}</div>
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>
  </div>

  <div class="back-link-wrap">
    <a class="back-link" href="/">← back</a>
  </div>
  <Footer />
</div>
</BaseLayout>